# LLM providers
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
# Optional override; defaults to gpt-image-1. Set to "dall-e-3" for legacy.
OPENAI_IMAGE_MODEL=gpt-image-1

# Storage (required in production — local dev falls back to file:./mastra.db)
# turso db create infopix && turso db show infopix --url && turso db tokens create infopix
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# WhatsApp / Spoki integration (optional)
SPOKI_API_KEY=
SPOKI_AUTOMATION_URL=
SPOKI_AUTOMATION_SECRET=
SPOKI_BOT_PHONE=
SPOKI_WEBHOOK_SECRET=
